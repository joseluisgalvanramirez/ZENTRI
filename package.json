{
  "name": "zentri-vocacional",
  "version": "1.0.0",
  "description": "Plataforma de orientación vocacional con IA - Descubre tu verdadera vocación profesional",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "dev-windows": "nodemon server.js",
    "dev-mac": "nodemon server.js",
    "db:init": "sqlite3 zentri_db.sqlite < database.sql",
    "db:init-windows": "type database.sql | sqlite3 zentri_db.sqlite",
    "test": "echo \"Error: no test specified\" && exit 1",
    "verificar": "node -e \"console.log('Node version:', process.version); console.log('Directorio actual:', process.cwd());\""
  },
  "keywords": [
    "vocacional",
    "orientacion",
    "carreras",
    "universidad",
    "ia",
    "inteligencia-artificial",
    "educacion",
    "test-vocacional"
  ],
  "author": "Zentri Team",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "sqlite3": "^5.1.6",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "compression": "^1.7.4",
    "helmet": "^7.0.0",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "eslint": "^8.49.0",
    "eslint-config-prettier": "^9.0.0",
    "prettier": "^3.0.3"
  },
  "engines": {
    "node": ">=14.0.0",
    "npm": ">=6.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/tuusuario/zentri-vocacional.git"
  },
  "bugs": {
    "url": "https://github.com/tuusuario/zentri-vocacional/issues"
  },
  "homepage": "https://github.com/tuusuario/zentri-vocacional#readme"
}

